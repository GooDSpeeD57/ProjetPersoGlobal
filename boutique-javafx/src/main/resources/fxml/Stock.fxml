<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.monprojet.boutiquejeux.controller.StockController"
      spacing="16" styleClass="view-container">
    <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

    <Label text="📦 Gestion du stock" styleClass="page-title"/>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="rechercheField" promptText="Rechercher un produit…" styleClass="text-field-dark" prefWidth="280"/>
        <ComboBox fx:id="filtreType" prefWidth="130"/>
        <Button text="🔍 Rechercher" onAction="#handleRecherche" styleClass="btn-secondary"/>
        <Button text="🔄 Actualiser" onAction="#handleRefresh"   styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelTotalRefs" styleClass="field-label"/>
        <ProgressIndicator fx:id="spinner" maxWidth="26" maxHeight="26"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <!-- Table stock -->
        <TableView fx:id="tableStock" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="table-dark">
            <columns>
                <TableColumn fx:id="colNom"    text="Produit"   prefWidth="220"/>
                <TableColumn fx:id="colGenre"  text="Genre"     prefWidth="100"/>
                <TableColumn fx:id="colType"   text="Type"      prefWidth="80"/>
                <TableColumn fx:id="colQte"    text="Quantité"  prefWidth="80"/>
                <TableColumn fx:id="colPrix"   text="Prix"      prefWidth="80"/>
                <TableColumn fx:id="colAlerte" text="Statut"    prefWidth="100"/>
            </columns>
        </TableView>

        <!-- Panneau modification -->
        <VBox styleClass="card" spacing="14" prefWidth="280">
            <Label text="Modifier le stock" styleClass="section-title"/>
            <Label text="Produit sélectionné :" styleClass="field-label"/>
            <Label fx:id="labelProduitSelec" text="—" styleClass="info-label" wrapText="true"/>
            <Label text="Nouvelle quantité" styleClass="field-label"/>
            <Spinner fx:id="spinnerQte" editable="true" styleClass="spinner-dark" maxWidth="Infinity"/>
            <Button fx:id="btnMettreAJour" text="💾 Mettre à jour" onAction="#handleMettreAJour"
                    styleClass="btn-primary" maxWidth="Infinity"/>
        </VBox>
    </HBox>
</VBox>
